{
  "name": "vantage",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": "20"
  },
  "scripts": {
    "dev": "concurrently -n web,api -c cyan,magenta \"pnpm --filter @vantage/web dev\" \"pnpm --filter @vantage/api dev\"",
    "build": "pnpm --filter @vantage/shared-types build && pnpm --filter @vantage/prompts build && pnpm --filter @vantage/api build && pnpm --filter @vantage/web build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
