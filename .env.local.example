# Copy to apps/web/.env.local and apps/api/.env (or root .env loaded by api)

# Supabase (nexus-core)
SUPABASE_URL=https://yrvdxofquvprklzsxoav.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# API (Hono)
PORT=8787
# Allowed CORS origins (comma-separated for multiple).
CORS_ORIGIN=http://localhost:5173
# Canonical web-app origin the OAuth callback redirects back to after connecting a
# channel. Use a SINGLE url (not the CORS_ORIGIN list). Falls back to the first
# CORS_ORIGIN entry if unset. e.g. https://vantage.bioloopnexus.com
WEB_APP_URL=http://localhost:5173

# ── LLM providers (multi-model) ──────────────────────────────────────────────
# Configure any subset; a task uses its per-workspace choice (Settings), else the
# env default below, else the first provider with a key. Anthropic is the default.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
GROK_API_KEY=
# Default provider per task: anthropic | openai | grok. LLM_PROVIDER is the global
# fallback; the per-task vars override it for that task.
LLM_PROVIDER=anthropic
LLM_PROVIDER_GENERATE=
LLM_PROVIDER_AUDIT=

# ── Distribution channel OAuth ────────────────────────────────────────────────
# Redirect URIs must match the provider app config EXACTLY (lowercase slug, no
# trailing slash). In production use your API host, e.g.
# https://<your-api>/v1/channels/<slug>/auth/callback

# X (Twitter) OAuth 2.0 — user context for post + webhooks
X_CLIENT_ID=
X_CLIENT_SECRET=
X_REDIRECT_URI=http://localhost:8787/v1/channels/x/auth/callback
# Webhook CRC / signature (OAuth 2.0 client secret often used for CRC per X docs)
X_WEBHOOK_SECRET=

# LinkedIn OAuth 2.0 (scopes: openid profile w_member_social)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:8787/v1/channels/linkedin/auth/callback
LINKEDIN_WEBHOOK_SECRET=

# Reddit OAuth 2.0 — create a "web app" (has a secret) at reddit.com/prefs/apps.
# The App ID (string under the app name) is REDDIT_CLIENT_ID.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_REDIRECT_URI=http://localhost:8787/v1/channels/reddit/auth/callback
# Reddit 403s generic User-Agents. Use its required format with YOUR username:
# "<platform>:<app id>:<version> (by /u/<your reddit username>)"
REDDIT_USER_AGENT=web:vantage:1.0.0 (by /u/your_reddit_username)
# Reddit hard-blocks datacenter IPs (Railway/GCP) at its edge → 403. If blocked,
# route Reddit calls through a residential/clean-IP proxy. Leave empty otherwise.
# Format: http://user:pass@host:port
REDDIT_PROXY_URL=

# Threads (Meta Graph API) OAuth 2.0 (scopes: threads_basic threads_content_publish)
THREADS_CLIENT_ID=
THREADS_CLIENT_SECRET=
THREADS_REDIRECT_URI=http://localhost:8787/v1/channels/threads/auth/callback

# Bluesky (AT Protocol) — connected per-workspace in the UI with a handle + app
# password; no app credentials needed. Override the PDS only when self-hosting.
# BLUESKY_PDS_URL=https://bsky.social

# Email (Resend) — the email channel adapter + webhook
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=
# RESEND_WEBHOOK_SECRET=

# Web SPA (Vite — build-time)
VITE_SUPABASE_URL=https://yrvdxofquvprklzsxoav.supabase.co
VITE_SUPABASE_ANON_KEY=
VITE_VANTAGE_API_URL=http://localhost:8787
# Nexus SSO app URL — unauthenticated users are redirected here to sign in.
# BioLoop suite shares the nexus-core Supabase; Nexus returns the session in the URL hash.
VITE_NEXUS_AUTH_URL=https://your-nexus-sso.example.com
